# Chrome extension local config (do not commit)
extension/config.js

# Firebase/Google services (Security sensitive)
**/google-services.json
**/GoogleService-Info.plist

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
