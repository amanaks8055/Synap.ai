# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# App Signing (Safety First)
*.jks
*.keystore
android/key.properties

# Diagnostic & temp files (Security: may expose internal metadata)
security_report*.json
broken_tools.json
cols.json
analyze_out*.txt
analyze_output*.txt
logcat_tools.txt
