<?xml version="1.0" encoding="utf-8"?>
<!-- ═══════════════════════════════════════════
     android/app/src/main/res/layout/native_ad_dark.xml

     Dark theme native ad — Simplified to avoid CardView/Material dependencies
     Uses custom background drawable: @drawable/native_ad_bg
     ═══════════════════════════════════════════ -->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:background="@drawable/native_ad_bg"
        android:layout_margin="4dp">

        <!-- App icon -->
        <ImageView
            android:id="@+id/ad_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:background="#1A1A2E"
            android:padding="4dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <!-- Headline -->
            <TextView
                android:id="@+id/ad_headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Body -->
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="3dp"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- CTA Button (using TextView as button) -->
        <TextView
            android:id="@+id/ad_call_to_action"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:background="#7B61FF"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </LinearLayout>

</com.google.android.gms.ads.nativead.NativeAdView>
